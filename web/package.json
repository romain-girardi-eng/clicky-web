{
  "name": "clicky-web-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Embeddable AI companion for the web. Watches the page, talks with the user, points and acts on UI elements.",
  "author": "Romain Girardi",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter=\"./packages/*\" build",
    "test": "pnpm -r --filter=\"./packages/*\" test",
    "typecheck": "pnpm -r --filter=\"./packages/*\" typecheck",
    "lint": "echo skip",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2",
    "jsdom": "^25.0.1"
  },
  "packageManager": "pnpm@10.18.3"
}
